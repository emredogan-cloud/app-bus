{
  "name": "@app-bus/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "App-Bus mobile app (Expo + React Native)",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform all",
    "lint": "eslint app src",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "clean": "rm -rf .expo dist"
  },
  "dependencies": {
    "@app-bus/api-client": "workspace:^",
    "@app-bus/types": "workspace:*",
    "@expo/vector-icons": "^14.0.4",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.0.0",
    "@sentry/react-native": "~6.0.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "^55.0.13",
    "expo-localization": "^55.0.13",
    "expo-router": "~4.0.0",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.0",
    "i18next": "^26.0.8",
    "react": "18.3.1",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.0.0",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@app-bus/config": "workspace:*",
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^29.5.13",
    "@types/react": "~18.3.12",
    "babel-jest": "^30.3.0",
    "eslint": "^10.3.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.6.3"
  }
