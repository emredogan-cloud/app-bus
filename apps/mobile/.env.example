# Expo public env (visible in client bundle — never put secrets here)
EXPO_PUBLIC_API_URL=http://localhost:3000

# KVKK consent version client must POST to /v1/auth/register. Bump to invalidate
# all existing consents and force re-acceptance.
EXPO_PUBLIC_KVKK_VERSION=2026-05-05

# Sentry (optional)
# EXPO_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=app-bus
# SENTRY_PROJECT=mobile

# EAS
# EAS_PROJECT_ID=
