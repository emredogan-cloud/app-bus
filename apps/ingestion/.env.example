APP_ENV=development
LOG_LEVEL=info
SERVICE_VERSION=0.0.0
HEALTH_ADDR=:8080
METRICS_ADDR=:9090

# Sources (URLs of vehicle position feeds). With none set the worker idles.
# SOURCE_IETT_URL=
# SOURCE_IETT_INTERVAL_S=15
# SOURCE_EGO_URL=
# SOURCE_EGO_INTERVAL_S=20

# Sinks. With none set the worker logs every 50th position to stderr.
# REDIS_URL=redis://localhost:6379
# MQTT_URL=tcp://localhost:1883
# MQTT_CLIENT_ID=app-bus-ingestion
# TIMESCALE_DSN=postgres://app_bus:app_bus@localhost:5432/app_bus

# SENTRY_DSN=
