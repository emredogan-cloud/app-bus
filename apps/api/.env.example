# API env (Phase 1). Copy to .env.local and fill in.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8081,http://localhost:3000
PUBLIC_API_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3000
APP_DEEP_LINK_SCHEME=appbus-dev

# ── Postgres ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app_bus:app_bus@localhost:5432/app_bus?schema=public

# ── Redis (optional in dev — token-bucket falls back to in-memory) ────────
# REDIS_URL=redis://localhost:6379

# ── Sentry ────────────────────────────────────────────────────────────────
# SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── JWT ───────────────────────────────────────────────────────────────────
# Modes: inline | file | secret | generate (dev only — ephemeral keypair)
JWT_KEY_SOURCE=generate
# Set when JWT_KEY_SOURCE=inline (multiline-safe via .env.local quoting):
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----..."
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----..."
# Or paths if file:
# JWT_PRIVATE_KEY_FILE=./keys/jwt-private.pem
# JWT_PUBLIC_KEY_FILE=./keys/jwt-public.pem
# Or AWS Secrets Manager ARN if secret:
# JWT_KEY_SECRET_ARN=arn:aws:secretsmanager:eu-central-1:...
JWT_ISSUER=app-bus
JWT_AUDIENCE=app-bus.tr
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ── KVKK ──────────────────────────────────────────────────────────────────
# Bump when consent text changes; clients must re-accept this exact version on register.
KVKK_CURRENT_VERSION=2026-05-05

# ── Email / SMS adapters ──────────────────────────────────────────────────
EMAIL_ADAPTER=dev
SES_REGION=eu-central-1
EMAIL_FROM=no-reply@app-bus.tr

SMS_ADAPTER=dev
# ILETIMERKEZI_USER=
# ILETIMERKEZI_PASSWORD=
ILETIMERKEZI_SENDER=APPBUS

# ── OAuth ─────────────────────────────────────────────────────────────────
# Comma-separated client IDs. iOS bundle id, Android android client id, web client id, etc.
OAUTH_GOOGLE_CLIENT_IDS=
OAUTH_APPLE_CLIENT_IDS=
