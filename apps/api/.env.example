# Phase 0 baseline env. Copy to .env.local and fill in.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Postgres (use the local docker-compose service from infra/local in dev)
DATABASE_URL=postgresql://app_bus:app_bus@localhost:5432/app_bus?schema=public

# Redis (optional in Phase 0)
# REDIS_URL=redis://localhost:6379

# Sentry (optional)
# SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
