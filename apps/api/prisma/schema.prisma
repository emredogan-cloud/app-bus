// Prisma schema — Phase 1: auth + KVKK.
// Phases 2+ will add City/Operator/Route/Stop/Vehicle/etc.

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis(version: "3.4"), citext, pg_trgm, unaccent]
}

enum Locale {
  tr
  en
}

enum PremiumTier {
  free
  premium
}

enum OAuthProvider {
  google
  apple
}

enum DeleteStatus {
  active
  pending_purge // soft-deleted, awaiting 90d purge
  purged        // PII anonymized
}

enum CityCode {
  IST
  ANK
  IZM // Izmir — Phase 10
  BUR // Bursa — Phase 10
  ANT // Antalya — Phase 10
}

enum SourceType {
  GTFS_STATIC
  GTFS_RT
  CUSTOM_REST
  CUSTOM_SCRAPE
}

enum TransitMode {
  bus
  metro
  tram
  ferry
  funicular
}

enum Direction {
  outbound // 0
  inbound  // 1
}

enum FavoriteTarget {
  stop
  route
}

enum DevicePlatform {
  ios
  android
  web
}

enum NotificationStatus {
  queued
  sent
  failed
  skipped
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique @db.Citext
  email_verified Boolean      @default(false)
  password_hash  String?      // null when only OAuth
  name           String       @db.VarChar(120)
  locale         Locale       @default(tr)
  phone_e164     String?      @db.VarChar(20)
  premium_tier   PremiumTier  @default(free)
  delete_status  DeleteStatus @default(active)
  delete_purge_at DateTime?   @db.Timestamptz(6)
  created_at     DateTime     @default(now()) @db.Timestamptz(6)
  updated_at     DateTime     @updatedAt @db.Timestamptz(6)

  refresh_tokens          RefreshToken[]
  oauth_identities        OAuthIdentity[]
  kvkk_consents           KvkkConsent[]
  email_verification_tokens EmailVerificationToken[]
  password_reset_tokens   PasswordResetToken[]
  favorites               UserFavorite[]
  notification_rules      NotificationRule[]
  notification_logs       NotificationLog[]
  device_tokens           DeviceToken[]

  @@index([delete_status, delete_purge_at])
  @@map("users")
}

// Refresh tokens are tracked by family. Reuse of an already-rotated token in a family
// invalidates the entire family (suspected theft).
model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  family_id   String    @db.Uuid
  // sha256 of the random secret. The plaintext token returned to the client encodes id|secret.
  token_hash  String    @unique
  // Marker if this token was rotated (became parent of a successor in same family)
  rotated_at  DateTime? @db.Timestamptz(6)
  // Set when explicit logout / family-wide revocation occurs
  revoked_at  DateTime? @db.Timestamptz(6)
  expires_at  DateTime  @db.Timestamptz(6)
  user_agent  String?   @db.VarChar(255)
  ip          String?   @db.Inet
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([family_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

model OAuthIdentity {
  id               String        @id @default(uuid()) @db.Uuid
  user_id          String        @db.Uuid
  provider         OAuthProvider
  provider_user_id String        @db.VarChar(255)
  email            String?       @db.Citext
  created_at       DateTime      @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
  @@index([user_id])
  @@map("oauth_identities")
}

// KVKK requires a versioned, immutable record of consent.
model KvkkConsent {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           String   @db.Uuid
  version           String   @db.VarChar(32)
  marketing_opt_in  Boolean  @default(false)
  ip                String?  @db.Inet
  user_agent        String?  @db.VarChar(255)
  accepted_at       DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, version])
  @@map("kvkk_consents")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("email_verification_tokens")
}

// ── Transit static data (Phase 2) ───────────────────────────────────────────

model City {
  id        String     @id @default(uuid()) @db.Uuid
  code      CityCode   @unique
  name      String     @db.VarChar(120)
  timezone  String     @db.VarChar(40)
  // bbox geometry stored via raw SQL — omitted here to keep Prisma generator happy.
  active    Boolean    @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)

  operators Operator[]
  routes    Route[]
  stops     Stop[]

  @@map("cities")
}

model Operator {
  id          String     @id @default(uuid()) @db.Uuid
  city_id     String     @db.Uuid
  code        String     @db.VarChar(40) // e.g. "iett", "ego"
  name        String     @db.VarChar(120)
  source_type SourceType
  // api_config holds source-specific config (URLs, headers, etc.) — encrypted at rest by RDS
  api_config  Json       @db.JsonB
  active      Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @updatedAt @db.Timestamptz(6)

  city   City    @relation(fields: [city_id], references: [id])
  routes Route[]
  stops  Stop[]

  @@unique([city_id, code])
  @@map("operators")
}

model Route {
  id           String      @id @default(uuid()) @db.Uuid
  operator_id  String      @db.Uuid
  city_id      String      @db.Uuid
  // Stable cross-source id (e.g. operator + external_id)
  external_id  String      @db.VarChar(120)
  code         String      @db.VarChar(40) // e.g. "500T"
  name_tr      String      @db.VarChar(255)
  name_en      String?     @db.VarChar(255)
  mode         TransitMode
  // Optional grouping for variants (500T, 500T1, 500T2)
  route_family_id String? @db.VarChar(40)
  // Route shape stored as PostGIS geometry(LineString,4326); managed via raw SQL.
  active       Boolean     @default(true)
  created_at   DateTime    @default(now()) @db.Timestamptz(6)
  updated_at   DateTime    @updatedAt @db.Timestamptz(6)

  operator    Operator    @relation(fields: [operator_id], references: [id])
  city        City        @relation(fields: [city_id], references: [id])
  route_stops RouteStop[]
  schedules   ScheduleEntry[]

  @@unique([operator_id, external_id])
  @@index([city_id, mode, active])
  @@index([code])
  @@map("routes")
}

model Stop {
  id          String   @id @default(uuid()) @db.Uuid
  operator_id String   @db.Uuid
  city_id     String   @db.Uuid
  external_id String   @db.VarChar(120)
  name_tr     String   @db.VarChar(255)
  name_en     String?  @db.VarChar(255)
  // Lat/Lng kept as floats for cheap reads; canonical geometry(Point,4326) lives in PostGIS column "location".
  lat         Float    @db.DoublePrecision
  lng         Float    @db.DoublePrecision
  accessibility_features Json? @db.JsonB
  active      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  operator    Operator    @relation(fields: [operator_id], references: [id])
  city        City        @relation(fields: [city_id], references: [id])
  route_stops RouteStop[]
  schedules   ScheduleEntry[]

  @@unique([operator_id, external_id])
  @@index([city_id])
  @@map("stops")
}

model RouteStop {
  id        String    @id @default(uuid()) @db.Uuid
  route_id  String    @db.Uuid
  stop_id   String    @db.Uuid
  sequence  Int
  direction Direction
  // Pre-computed distance from route start to this stop along the shape (Phase 5 ETA)
  distance_along_shape_m Int?

  route Route @relation(fields: [route_id], references: [id], onDelete: Cascade)
  stop  Stop  @relation(fields: [stop_id], references: [id], onDelete: Cascade)

  @@unique([route_id, direction, sequence])
  @@index([stop_id])
  @@map("route_stops")
}

// Static schedule entries — used as ETA fallback (Phase 5).
model ScheduleEntry {
  id        String    @id @default(uuid()) @db.Uuid
  route_id  String    @db.Uuid
  stop_id   String    @db.Uuid
  direction Direction
  // Bitmask of days: bit 0 = Monday, bit 6 = Sunday
  days_of_week Int
  // Seconds from local-midnight at the stop
  departure_seconds_from_midnight Int

  route Route @relation(fields: [route_id], references: [id], onDelete: Cascade)
  stop  Stop  @relation(fields: [stop_id], references: [id], onDelete: Cascade)

  @@index([stop_id, days_of_week, departure_seconds_from_midnight])
  @@index([route_id])
  @@map("schedule_entries")
}

model ImportRun {
  id          String   @id @default(uuid()) @db.Uuid
  operator_id String   @db.Uuid
  source_url  String?  @db.Text
  status      String   @db.VarChar(40) // running | success | failed
  stats       Json?    @db.JsonB
  error       String?  @db.Text
  started_at  DateTime @default(now()) @db.Timestamptz(6)
  finished_at DateTime? @db.Timestamptz(6)

  @@index([operator_id, started_at])
  @@map("import_runs")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  ip         String?   @db.Inet
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

// ── Favorites + Notifications (Phase 6) ────────────────────────────────────

model UserFavorite {
  id          String         @id @default(uuid()) @db.Uuid
  user_id     String         @db.Uuid
  target_type FavoriteTarget
  target_id   String         @db.Uuid
  label       String?        @db.VarChar(120)
  sort_order  Int            @default(0)
  created_at  DateTime       @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, target_type, target_id])
  @@index([user_id, sort_order])
  @@map("user_favorites")
}

model NotificationRule {
  id                   String   @id @default(uuid()) @db.Uuid
  user_id              String   @db.Uuid
  // Rule fires for stop/route pairs (route_id may be null = "any line at this stop")
  stop_id              String   @db.Uuid
  route_id             String?  @db.Uuid
  threshold_minutes    Int      // notify when ETA equals this many minutes
  // Bitmask of weekdays: bit 0 = Monday, bit 6 = Sunday
  days_of_week_bitmask Int      @default(127)
  // Quiet-hours window in minutes-from-midnight (local). NULL = no quiet hours.
  quiet_hours_start_min Int?
  quiet_hours_end_min   Int?
  enabled              Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, enabled])
  @@index([stop_id])
  @@map("notification_rules")
}

model NotificationLog {
  id              String             @id @default(uuid()) @db.Uuid
  user_id         String             @db.Uuid
  rule_id         String             @db.Uuid
  eta_unix        Int
  sent_at         DateTime?          @db.Timestamptz(6)
  status          NotificationStatus
  expo_receipt_id String?            @db.VarChar(120)
  // sha256("{user_id}:{rule_id}:{eta_unix_rounded_to_60s}") — prevents dupes on worker restart
  idempotency_key String             @unique
  created_at      DateTime           @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, sent_at])
  @@map("notification_logs")
}

model DeviceToken {
  id              String         @id @default(uuid()) @db.Uuid
  user_id         String         @db.Uuid
  expo_push_token String         @unique
  platform        DevicePlatform
  last_seen_at    DateTime       @default(now()) @db.Timestamptz(6)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("device_tokens")
}
