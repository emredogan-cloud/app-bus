auto-install-peers=true
strict-peer-dependencies=false

# Expo + React Native + Metro need a flatter tree than pnpm's isolated default
# (Metro can't follow symlinks across .pnpm/ to reach transitive Babel/runtime
# helpers). The standard Expo + pnpm guide enables hoisting; we honor that.
node-linker=hoisted
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=metro*
public-hoist-pattern[]=whatwg-*
