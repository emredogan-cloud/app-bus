# Root-level env example. Per-app .env.example files live alongside each app.
# Copy each per-app file to .env.local in that app directory:
#   cp apps/api/.env.example apps/api/.env.local
#   cp apps/mobile/.env.example apps/mobile/.env.local
#   cp apps/ingestion/.env.example apps/ingestion/.env

# Shared (used by docker compose locally)
POSTGRES_USER=app_bus
POSTGRES_PASSWORD=app_bus
POSTGRES_DB=app_bus
