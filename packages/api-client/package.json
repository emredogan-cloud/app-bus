{
  "name": "@app-bus/api-client",
  "version": "0.0.0",
  "private": true,
  "description": "Typed fetch wrapper with bearer auth + 401-driven refresh interceptor (single-flight)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
