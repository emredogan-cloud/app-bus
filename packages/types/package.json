{
  "name": "@app-bus/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod schemas + inferred TS types (used by api, mobile, web)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./transit": {
      "types": "./dist/transit.d.ts",
      "default": "./dist/transit.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "default": "./dist/common.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --outDir dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@app-bus/config": "workspace:*",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
