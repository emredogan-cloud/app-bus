{
  "name": "@app-bus/types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod schemas + inferred TS types (used by api, mobile, web)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./transit": "./src/transit.ts",
    "./common": "./src/common.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --emitDeclarationOnly --declaration --outDir dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@app-bus/config": "workspace:*",
    "eslint": "^10.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
